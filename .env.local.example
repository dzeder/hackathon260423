# Copy to .env.local and fill in. Never commit .env.local.

# Core
ANTHROPIC_API_KEY=sk-ant-...

# Track B — event MCP servers
CFBD_API_KEY=                     # free at collegefootballdata.com
NOAA_USER_AGENT="ohanafy-hackathon (contact@ohanafy.com)"
EIA_API_KEY=                      # free at eia.gov

# Track B — network MCP server
AWS_REGION=us-east-1
OHANAFY_NETWORK_TABLE=ohanafy-plan-network-signals-hack
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Observability (all tracks)
DD_API_KEY=
DD_SITE=datadoghq.com
DD_ENV=hackathon
DD_SERVICE=ohanafy-plan
DD_VERSION=0.1.0

# Datadog RUM (Track A, browser-side)
NEXT_PUBLIC_DATADOG_RUM_APPLICATION_ID=
NEXT_PUBLIC_DATADOG_RUM_CLIENT_TOKEN=

# Salesforce sandbox (Track C)
SF_SANDBOX_ALIAS=ohanafy-hack-sandbox
