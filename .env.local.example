# Copy to .env.local and fill in. Never commit .env.local.
#
# SECURITY NOTES (production):
#   - Secrets live in Vercel env vars (production/preview) or GitHub Actions
#     secrets (CI), never in committed files.
#   - Do NOT store the Anthropic API key in a Salesforce Custom Metadata
#     record. The sibling forecasting-agent team did this; see the handoff
#     doc — that key had to be rotated. All LLM traffic routes through the
#     web-app; Salesforce calls /api/copilot via the Ohanafy_Plan_Gateway
#     Named Credential, which does NOT carry the key.
#   - If a key appears in any commit, rotate it immediately, then add a
#     DECISION_LOG.md entry. gitleaks runs on every PR (.github/workflows/
#     secret-scan.yml) and will block merges on detection.

# Core
ANTHROPIC_API_KEY=sk-ant-...

# Copilot (Track A — web app)
#
# Conversation memory lives in the customer's Salesforce org via the
# OhfyPlanMemoryStore Apex REST endpoint — the same Connected App used for
# live SOQL handles auth. No separate database service to provision.

# Shared secret between the Salesforce Apex gateway and /api/copilot. Rotate
# quarterly: add new value to COPILOT_CLIENT_SECRETS (comma-separated) in both
# places, redeploy, verify, remove old.
COPILOT_CLIENT_SECRET=              # 32-char random, e.g. `openssl rand -hex 32`
COPILOT_CLIENT_SECRETS=             # comma-separated during rotation
COPILOT_REQUIRE_AUTH_IN_DEV=        # set to "1" to require auth locally

# Single-customer deploy tag. Every row persisted is scoped to this customer_id.
SF_CUSTOMER_ID=yellowhammer

# Rate + cost caps (optional — sensible defaults apply)
COPILOT_MAX_TURNS_PER_DAY=200
COPILOT_MAX_COST_USD_PER_DAY=25
COPILOT_MAX_COST_USD_PER_TURN=0.30

# Salesforce — REQUIRED for memory + live SOQL.
#
# Memory: copilot conversations + messages + usage live in
# Plan_Conversation__c / Plan_Message__c / Plan_Usage_Daily__c via the
# OhfyPlanMemoryStore Apex REST endpoint. Without these env vars, memory is
# unavailable and turns are stateless.
#
# SOQL: query_salesforce tool runs read-only via OhfyPlanSoqlReader. Without
# these env vars, the tool returns canned Yellowhammer fixtures.
#
# Connected App setup:
#   1. Setup → App Manager → New Connected App
#   2. Enable OAuth + check "Enable Client Credentials Flow"
#   3. Scopes: Manage user data via APIs (api), Perform requests at any time (refresh_token)
#   4. Run As: integration user with a permission set granting:
#        - Read on Account, Contact, Opportunity, User, Order, ohfy__*
#        - Read/Create/Edit on Plan_Conversation__c, Plan_Message__c, Plan_Usage_Daily__c
#   5. Deploy force-app/ — installs both Apex REST endpoints + the 3 memory
#      objects + the LWC.
SF_LOGIN_URL=                       # e.g. https://yellowhammer.my.salesforce.com
SF_CONSUMER_KEY=                    # Connected App consumer key
SF_CONSUMER_SECRET=                 # Connected App consumer secret

# Track B — event MCP servers
CFBD_API_KEY=                     # free at collegefootballdata.com
NOAA_USER_AGENT="ohanafy-hackathon (contact@ohanafy.com)"
EIA_API_KEY=                      # free at eia.gov

# Track B — network MCP server
AWS_REGION=us-east-1
OHANAFY_NETWORK_TABLE=ohanafy-plan-network-signals-hack
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Observability (all tracks)
DD_API_KEY=
# Datadog Application Key — required by ops/datadog/apply.sh and verify-deploy.sh
# to write dashboards / monitors and search via the v1/v2 APIs. Generate at
# https://app.datadoghq.com/organization-settings/application-keys (or your
# region's equivalent). Treat as a secret — same scope as DD_API_KEY.
DD_APP_KEY=
DD_SITE=datadoghq.com
DD_ENV=hackathon
DD_SERVICE=ohanafy-plan
DD_VERSION=0.1.0

# Datadog RUM (Track A, browser-side)
NEXT_PUBLIC_DATADOG_RUM_APPLICATION_ID=
NEXT_PUBLIC_DATADOG_RUM_CLIENT_TOKEN=

# Salesforce sandbox (Track C)
SF_SANDBOX_ALIAS=ohanafy-hack-sandbox
SF_LOGIN=                         # sandbox username, e.g. dzeder@example.com.ohanafyhack
SF_PW=                            # sandbox password + security token (concat)
SF_URL=                           # login URL, typically https://test.salesforce.com
