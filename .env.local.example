# Copy to .env.local and fill in. Never commit .env.local.

# Core
ANTHROPIC_API_KEY=sk-ant-...

# Copilot (Track A — web app)
#
# Turso (libSQL) — SQLite-compatible remote database. In prod, create a DB via
# `turso db create ohanafy-copilot-<customer>` then `turso db tokens create`.
# Locally, leave TURSO_DATABASE_URL unset to fall back to `file:./data/copilot.db`.
TURSO_DATABASE_URL=                 # e.g. libsql://ohanafy-copilot-yellowhammer-xxxx.turso.io
TURSO_AUTH_TOKEN=                   # long JWT from `turso db tokens create`

# Shared secret between the Salesforce Apex gateway and /api/copilot. Rotate
# quarterly: add new value to COPILOT_CLIENT_SECRETS (comma-separated) in both
# places, redeploy, verify, remove old.
COPILOT_CLIENT_SECRET=              # 32-char random, e.g. `openssl rand -hex 32`
COPILOT_CLIENT_SECRETS=             # comma-separated during rotation
COPILOT_REQUIRE_AUTH_IN_DEV=        # set to "1" to require auth locally

# Single-customer deploy tag. Every row persisted is scoped to this customer_id.
SF_CUSTOMER_ID=yellowhammer

# Rate + cost caps (optional — sensible defaults apply)
COPILOT_MAX_TURNS_PER_DAY=200
COPILOT_MAX_COST_USD_PER_DAY=25
COPILOT_MAX_COST_USD_PER_TURN=0.30

# Track B — event MCP servers
CFBD_API_KEY=                     # free at collegefootballdata.com
NOAA_USER_AGENT="ohanafy-hackathon (contact@ohanafy.com)"
EIA_API_KEY=                      # free at eia.gov

# Track B — network MCP server
AWS_REGION=us-east-1
OHANAFY_NETWORK_TABLE=ohanafy-plan-network-signals-hack
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Observability (all tracks)
DD_API_KEY=
DD_SITE=datadoghq.com
DD_ENV=hackathon
DD_SERVICE=ohanafy-plan
DD_VERSION=0.1.0

# Datadog RUM (Track A, browser-side)
NEXT_PUBLIC_DATADOG_RUM_APPLICATION_ID=
NEXT_PUBLIC_DATADOG_RUM_CLIENT_TOKEN=

# Salesforce sandbox (Track C)
SF_SANDBOX_ALIAS=ohanafy-hack-sandbox
SF_LOGIN=                         # sandbox username, e.g. dzeder@example.com.ohanafyhack
SF_PW=                            # sandbox password + security token (concat)
SF_URL=                           # login URL, typically https://test.salesforce.com
