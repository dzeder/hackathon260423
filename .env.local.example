# Copy to .env.local and fill in. Never commit .env.local.
#
# SECURITY NOTES (production):
#   - Secrets live in Vercel env vars (production/preview) or GitHub Actions
#     secrets (CI), never in committed files.
#   - Do NOT store the Anthropic API key in a Salesforce Custom Metadata
#     record. The sibling forecasting-agent team did this; see the handoff
#     doc — that key had to be rotated. All LLM traffic routes through the
#     web-app; Salesforce calls /api/copilot via the Ohanafy_Plan_Gateway
#     Named Credential, which does NOT carry the key.
#   - If a key appears in any commit, rotate it immediately, then add a
#     DECISION_LOG.md entry. gitleaks runs on every PR (.github/workflows/
#     secret-scan.yml) and will block merges on detection.

# Core
ANTHROPIC_API_KEY=sk-ant-...

# Track B — event MCP servers
CFBD_API_KEY=                     # free at collegefootballdata.com
NOAA_USER_AGENT="ohanafy-hackathon (contact@ohanafy.com)"
EIA_API_KEY=                      # free at eia.gov

# Track B — network MCP server
AWS_REGION=us-east-1
OHANAFY_NETWORK_TABLE=ohanafy-plan-network-signals-hack
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Observability (all tracks)
DD_API_KEY=
DD_SITE=datadoghq.com
DD_ENV=hackathon
DD_SERVICE=ohanafy-plan
DD_VERSION=0.1.0

# Datadog RUM (Track A, browser-side)
NEXT_PUBLIC_DATADOG_RUM_APPLICATION_ID=
NEXT_PUBLIC_DATADOG_RUM_CLIENT_TOKEN=

# Salesforce sandbox (Track C)
SF_SANDBOX_ALIAS=ohanafy-hack-sandbox
SF_LOGIN=                         # sandbox username, e.g. dzeder@example.com.ohanafyhack
SF_PW=                            # sandbox password + security token (concat)
SF_URL=                           # login URL, typically https://test.salesforce.com
