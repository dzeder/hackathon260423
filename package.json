{
  "name": "ohanafy-plan-demo",
  "private": true,
  "version": "0.1.0",
  "description": "Ohanafy Plan — hackathon demo kernel (web app + MCP servers + SFDX 2GP).",
  "workspaces": [
    "packages/web-app",
    "packages/mcp-servers",
    "packages/mcp-servers/ohanafy-forecast",
    "packages/mcp-servers/ohanafy-events",
    "packages/mcp-servers/ohanafy-memory",
    "packages/mcp-servers/ohanafy-network"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "test:lwc": "sfdx-lwc-jest --skipApiVersionCheck -- --config jest.config.js",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "@salesforce/sfdx-lwc-jest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
